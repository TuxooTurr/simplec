# SimpleTest — локальная конфигурация (не коммитить!)

# Auth (COOKIE_SECURE=0 для localhost HTTP, на проде ставить 1)
COOKIE_SECURE=0
APP_SECRET=local-dev-secret-change-in-prod

# UI Defaults
DEFAULT_PLATFORM=W
DEFAULT_FEATURE=
LLM_PROVIDER=gigachat
USE_REAL_LLM=1

# GigaChat
GIGACHAT_AUTH_KEY=MDE5YmQxMjYtYWMwYi03MGY1LTk4ZTMtMDcyNGMzOTU2OWFkOjJjNjE3ZThhLTJjN2EtNGI4Ny1hZDYyLTI5NjU4NWFhODE2Ng==
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# DeepSeek
DEEPSEEK_API_KEY=sk-04e9f0efa50f4de19b582359c66d5cfc
DEEPSEEK_MODEL=deepseek-chat

# Ollama (локальный — автоопределение)
OLLAMA_MODEL=llama3.1

# LM Studio (локальный — автоопределение)
LMSTUDIO_URL=http://localhost:1234/v1
