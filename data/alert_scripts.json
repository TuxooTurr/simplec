    "payload_template": "{\n  \"as\": \"{{as}}\",\n  \"system\": \"TENGRI\",\n  \"ruleId\": \"{{rule_id}}\",\n  \"status\": \"{{status}}\",\n  \"timestamp\": \"{{timestamp}}\"\n}",
    "params": [
      {"key": "as",        "label": "КЭ/АС",     "type": "text",   "required": true,  "default": "CI0000000", "hint": "CI-код системы"},
      {"key": "rule_id",   "label": "Rule ID",   "type": "text",   "required": true,  "default": ""},
      {"key": "status",    "label": "Статус",    "type": "select", "required": true,  "default": "FIRING", "options": ["FIRING", "RESOLVED", "PENDING"]},
      {"key": "timestamp", "label": "Timestamp", "type": "text",   "required": false, "default": "__now__", "hint": "ISO 8601"}
    ],
    "created_at": "2026-03-03T00:00:00Z",
    "builtin": true
  },
  {
