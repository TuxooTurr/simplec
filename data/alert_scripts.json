      {"key": "status",           "label": "Статус",           "type": "select",   "required": false, "default": "ACTIVE", "options": ["ACTIVE", "COMPLETED", "CANCELLED"]},
      {"key": "sender",           "label": "Sender",           "type": "text",     "required": false, "default": "sber911.mpr_generator"},
      {"key": "recipient",        "label": "Recipient",        "type": "text",     "required": false, "default": "sber.support_platform.channel_agent"},
      {"key": "sender_id_aef",    "label": "Sender ID AEF",    "type": "text",     "required": false, "default": "CI00213821"},
      {"key": "recipient_id_aef", "label": "Recipient ID AEF", "type": "text",     "required": false, "default": "CI00293210"}
