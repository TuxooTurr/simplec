# SimpleTest — шаблон конфигурации
# Скопируйте в .env и заполните свои значения:
#   cp .env.example .env
#   chmod 600 .env

# ── Авторизация ───────────────────────────────────────────────
# Секрет для подписи JWT — сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=
# Первый администратор (создаётся при первом запуске, если нет пользователей)
# Пароль — минимум 12 символов, хотя бы одна буква и одна цифра
ADMIN_USER=admin
ADMIN_PASS=
# Время жизни сессии в часах (по умолчанию 24)
SESSION_HOURS=24
# Secure-флаг cookie: 1 (HTTPS/prod) или 0 (локальная разработка)
COOKIE_SECURE=1

# ── UI Defaults ───────────────────────────────────────────────
DEFAULT_PLATFORM=W
DEFAULT_FEATURE=
LLM_PROVIDER=gigachat

# ── GigaChat (обязательно) ────────────────────────────────────
# Base64-строка из личного кабинета: https://developers.sber.ru/studio
# Формат: base64(client_id:client_secret)
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_SCOPE=GIGACHAT_API_CORP  ← для корпоративного доступа

# ── DeepSeek (опционально) ────────────────────────────────────
# Получить ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Ollama (локальный, опционально) ───────────────────────────
# Установка: brew install ollama && ollama pull llama3.1
# Автоопределение: если запущен — появится в интерфейсе автоматически
OLLAMA_MODEL=llama3.1

# ── LM Studio (локальный, опционально) ────────────────────────
# Автоопределение: если запущен на порту 1234 — появится автоматически
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# ── Kafka (алерты) ────────────────────────────────────────────
# Адрес брокера (один или несколько через запятую)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Протокол: PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# SASL-механизм: PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512 (если SASL_*)
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Путь к CA-файлу (если SSL/SASL_SSL)
KAFKA_SSL_CAFILE=
# JWT-секрет для A2A-протокола — сгенерировать криптостойкий ключ:
#   python -c "import secrets; print(secrets.token_hex(32))"
A2A_JWT_SECRET=

# ── Ревизор стендов ───────────────────────────────────────────
# K8s API URL + токен + namespace для каждого стенда.
# Если поля пусты — Ревизор работает на mock-данных.
REVISOR_NT_URL=
REVISOR_NT_TOKEN=
REVISOR_NT_NAMESPACE=
REVISOR_MAJORCHECK_URL=
REVISOR_MAJORCHECK_TOKEN=
REVISOR_MAJORCHECK_NAMESPACE=
REVISOR_MAJORGO_URL=
REVISOR_MAJORGO_TOKEN=
REVISOR_MAJORGO_NAMESPACE=

# ── База данных ───────────────────────────────────────────────
# SQLite — без Docker, файл создаётся автоматически рядом с приложением:
DATABASE_URL=sqlite:///./simpletest.db
# PostgreSQL — раскомментировать и заменить при использовании PostgreSQL:
# DATABASE_URL=postgresql://simpletest:simpletest@localhost:5432/metrics

# ── OpenAI (опционально) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Claude / Anthropic (опционально) ─────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Прочее ────────────────────────────────────────────────────
USE_REAL_LLM=1
