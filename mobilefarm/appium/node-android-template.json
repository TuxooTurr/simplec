{
  "capabilities": [
    {
      "platformName": "Android",
      "appium:automationName": "UiAutomator2",
      "appium:deviceName": "${DEVICE_NAME}",
      "appium:platformVersion": "${PLATFORM_VERSION}",
      "appium:udid": "${UDID}"
    }
  ],
  "configuration": {
    "url": "http://${AGENT_HOST}:${APPIUM_PORT}/wd/hub",
    "maxSessions": 1,
    "timeout": 1800
  }
}
