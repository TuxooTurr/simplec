# SimpleTest — шаблон конфигурации
# Скопируйте в .env и заполните свои значения:
#   cp .env.example .env
#   chmod 600 .env

# В приложении нет пользовательской авторизации.
# Доступ ограничивается сетью/виртуальной машиной корпоративного контура.

# ── UI Defaults ───────────────────────────────────────────────
DEFAULT_PLATFORM=W
DEFAULT_FEATURE=
LLM_PROVIDER=gigachat

# ── GigaChat (обязательно) ────────────────────────────────────
# Base64-строка из личного кабинета: https://developers.sber.ru/studio
# Формат: base64(client_id:client_secret)
GIGACHAT_AUTH_TYPE=api_key
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_SCOPE=GIGACHAT_API_CORP  ← для корпоративного доступа
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_MODEL=GigaChat
# Для подключения через сертификат:
# GIGACHAT_AUTH_TYPE=certificate
# GIGACHAT_CA_CERT_PATH=/path/to/ca.pem
# GIGACHAT_CLIENT_CERT_PATH=/path/to/client.crt
# GIGACHAT_CLIENT_KEY_PATH=/path/to/client.key

# ── DeepSeek (опционально) ────────────────────────────────────
# Получить ключ: https://platform.deepseek.com
DEEPSEEK_AUTH_TYPE=api_key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# Для подключения через сертификат:
# DEEPSEEK_AUTH_TYPE=certificate
# DEEPSEEK_CA_CERT_PATH=/path/to/ca.pem
# DEEPSEEK_CLIENT_CERT_PATH=/path/to/client.crt
# DEEPSEEK_CLIENT_KEY_PATH=/path/to/client.key

# Дополнительные LLM добавляются через UI: Настройки → Дополнительные LLM.
# Поддерживается chat/completions-compatible endpoint через API key или сертификат.

# ── Kafka (общий fallback для KafkaClient + дефолт для Kafka-Метрик) ──
# Подключение к Kafka для алертов теперь описывается прямо в коде
# Jupyter-скрипта (см. раздел «Алерты»), настройки здесь не участвуют.
# Адрес брокера (один или несколько через запятую)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Протокол: PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# SASL-механизм: PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512 (если SASL_*)
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Путь к CA-файлу (если SSL/SASL_SSL)
KAFKA_SSL_CAFILE=
# JWT-секрет для A2A-протокола — сгенерировать криптостойкий ключ:
#   python -c "import secrets; print(secrets.token_hex(32))"
A2A_JWT_SECRET=

# ── Ревизор стендов ───────────────────────────────────────────
# Основная настройка делается в UI: Настройки → Ревизор — API стенды.
# Там задаются имя стенда, Base URL, auth и выбранные методы сравнения.
# Если UI-конфигурация пуста — Ревизор работает на mock-данных.
# Старые env-переменные оставлены как read-only fallback для статуса стендов.
REVISOR_NT_URL=
REVISOR_NT_TOKEN=
REVISOR_NT_NAMESPACE=
REVISOR_MAJORCHECK_URL=
REVISOR_MAJORCHECK_TOKEN=
REVISOR_MAJORCHECK_NAMESPACE=
REVISOR_MAJORGO_URL=
REVISOR_MAJORGO_TOKEN=
REVISOR_MAJORGO_NAMESPACE=

# ── База данных ───────────────────────────────────────────────
# SQLite — без Docker, файл создаётся автоматически рядом с приложением:
DATABASE_URL=sqlite:///./simpletest.db
# PostgreSQL — раскомментировать и заменить при использовании PostgreSQL:
# DATABASE_URL=postgresql://simpletest:simpletest@localhost:5432/metrics

# ── Корпоративные SSL-сертификаты (Sber BIG IP proxy) ─────────
# Нужно только в корпоративной сети с TLS-инспекцией.
# Сначала соберите bundle: bash certs/build_bundle.sh
# SSL_CERT_FILE=./certs/ca-bundle.pem
# REQUESTS_CA_BUNDLE=./certs/ca-bundle.pem

# ── Прочее ────────────────────────────────────────────────────
USE_REAL_LLM=1
